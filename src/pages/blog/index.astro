---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const base = import.meta.env.BASE_URL;

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categories = [...new Set(posts.map(p => p.data.category))];

const seo = {
  title: 'Blog - Guías y Análisis del Mercado de Cereales en España',
  description: 'Artículos, guías y análisis sobre el mercado de cereales en España. Aprende sobre lonjas, precios, estrategias de venta, la PAC y mucho más.',
};
---

<Layout seo={seo}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs items={[{ name: 'Blog', url: '/blog/' }]} />

    <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-2">Blog: Guías y Análisis del Mercado de Cereales</h1>
    <p class="text-gray-500 mb-10 max-w-3xl">
      Todo lo que necesitas saber sobre el mercado de cereales en España: cómo funcionan las lonjas, cuándo vender, ayudas de la PAC, tipos de cereales y mucho más.
    </p>

    <!-- Categorías -->
    <div class="flex flex-wrap gap-2 mb-8">
      {categories.map(cat => (
        <span class="bg-primary/10 text-primary text-sm font-medium px-4 py-1.5 rounded-full">
          {cat}
        </span>
      ))}
    </div>

    <!-- Grid de artículos -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map(post => (
        <a href={`${base}/blog/${post.id.replace(/\.md$/, '')}/`} class="group block bg-white border border-gray-200 rounded-xl overflow-hidden hover:shadow-lg hover:border-primary/30 transition-all duration-200">
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="bg-primary/10 text-primary text-xs font-semibold px-2.5 py-0.5 rounded-full">
                {post.data.category}
              </span>
              <span class="text-xs text-gray-400">{post.data.readingTime}</span>
            </div>
            <h2 class="text-lg font-bold text-gray-900 group-hover:text-primary transition-colors mb-2 line-clamp-3">
              {post.data.title}
            </h2>
            <p class="text-sm text-gray-500 line-clamp-3 mb-4">
              {post.data.description}
            </p>
            <div class="flex items-center justify-end">
              <span class="text-primary text-sm font-semibold group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
                Leer
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- SEO text -->
    <section class="mt-16 max-w-4xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Sobre nuestro blog de cereales</h2>
      <div class="prose prose-gray">
        <p>
          En esta sección publicamos guías completas y análisis sobre el mercado de cereales en España.
          Nuestro objetivo es ofrecer información útil y práctica para agricultores, cooperativas y
          profesionales del sector agrícola.
        </p>
        <p>
          Cubrimos temas como el funcionamiento de las lonjas de cereales, estrategias de comercialización
          de grano, ayudas de la PAC, tipos de cereales y oleaginosas, y todo lo que necesitas para tomar
          mejores decisiones en la venta de tu cosecha. Todos nuestros artículos se basan en datos
          oficiales y fuentes contrastadas.
        </p>
      </div>
    </section>
  </div>
</Layout>
