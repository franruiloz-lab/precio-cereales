---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const seo = {
  title: 'Blog - Análisis del Mercado de Cereales en España',
  description: 'Análisis semanal del mercado de cereales en España. Tendencias, previsiones de precios, impacto de la PAC y noticias del sector agrícola.',
};
---

<Layout seo={seo}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs items={[{ name: 'Blog', url: '/blog/' }]} />

    <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-2">Análisis del Mercado de Cereales</h1>
    <p class="text-gray-500 mb-10">
      Artículos, análisis semanales y noticias sobre el mercado de cereales en España y Europa.
    </p>

    <!-- Placeholder para cuando haya artículos -->
    <div class="bg-gray-50 rounded-xl border border-gray-200 p-12 text-center">
      <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
      </svg>
      <h2 class="text-xl font-bold text-gray-700 mb-2">Próximamente</h2>
      <p class="text-gray-500 max-w-md mx-auto">
        Estamos preparando nuestros primeros análisis semanales del mercado de cereales. Vuelve pronto para leer artículos sobre tendencias, previsiones y noticias del sector.
      </p>
    </div>

    <!-- Temas que cubriremos -->
    <section class="mt-12 max-w-4xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Temas que cubriremos</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex items-start gap-3 p-4 bg-white border border-gray-200 rounded-lg">
          <span class="text-primary text-xl mt-0.5">&#8226;</span>
          <div>
            <h3 class="font-semibold text-gray-900">Análisis semanal</h3>
            <p class="text-sm text-gray-500">Resumen de la evolución de precios cada semana</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-4 bg-white border border-gray-200 rounded-lg">
          <span class="text-primary text-xl mt-0.5">&#8226;</span>
          <div>
            <h3 class="font-semibold text-gray-900">Previsiones de mercado</h3>
            <p class="text-sm text-gray-500">Tendencias y proyecciones para la campaña</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-4 bg-white border border-gray-200 rounded-lg">
          <span class="text-primary text-xl mt-0.5">&#8226;</span>
          <div>
            <h3 class="font-semibold text-gray-900">PAC y política agrícola</h3>
            <p class="text-sm text-gray-500">Impacto de la normativa europea en los precios</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-4 bg-white border border-gray-200 rounded-lg">
          <span class="text-primary text-xl mt-0.5">&#8226;</span>
          <div>
            <h3 class="font-semibold text-gray-900">Mercado internacional</h3>
            <p class="text-sm text-gray-500">Influencia de los mercados globales en España</p>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
