---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getLonjas, getSemanaActual } from '../../utils/precios';
import { generateCollectionPageSchema } from '../../utils/seo';

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const lonjas = getLonjas();
const semana = getSemanaActual();

const seo = {
  title: 'Lonjas de Cereales en España - Todas las Lonjas Agropecuarias',
  description: `Listado completo de las ${lonjas.length} lonjas de cereales en España. Consulta cotizaciones, horarios de sesión y precios por lonja: León, Toledo, Sevilla, Albacete, Valladolid y más.`,
};

// Agrupar por comunidad autónoma
const porComunidad = lonjas.reduce((acc, lonja) => {
  if (!acc[lonja.comunidad]) acc[lonja.comunidad] = [];
  acc[lonja.comunidad].push(lonja);
  return acc;
}, {} as Record<string, typeof lonjas>);

const schema = [
  generateCollectionPageSchema(
    'Lonjas de Cereales en España',
    seo.description,
    '/lonjas/',
    lonjas.map(lonja => ({
      name: lonja.nombre,
      url: `/lonjas/${lonja.slug}/`,
      description: `${lonja.nombre} en ${lonja.ciudad} (${lonja.comunidad}). Sesión: ${lonja.diaSesion}.`,
    }))
  ),
];
---

<Layout seo={seo} schema={schema}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs items={[{ name: 'Lonjas', url: '/lonjas/' }]} />

    <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-2">Lonjas de Cereales en España</h1>
    <p class="text-gray-500 mb-10">
      Directorio completo de las {lonjas.length} lonjas agropecuarias que cotizan cereales en España, organizadas por comunidad autónoma.
    </p>

    {Object.entries(porComunidad).map(([comunidad, lonjasCC]) => (
      <section class="mb-10">
        <h2 class="text-xl font-bold text-gray-900 mb-4 border-b border-gray-200 pb-2">{comunidad}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {lonjasCC.map(lonja => {
            const preciosLonja = semana.precios[lonja.id];
            const numProductos = preciosLonja ? Object.keys(preciosLonja).length : 0;
            return (
              <a href={`${base}/lonjas/${lonja.slug}/`} class="bg-white border border-gray-200 rounded-lg p-5 hover:shadow-md hover:border-primary/30 transition-all group">
                <h3 class="font-semibold text-gray-900 group-hover:text-primary transition-colors">{lonja.nombre}</h3>
                <p class="text-sm text-gray-500 mt-1">{lonja.ciudad}</p>
                <div class="mt-3 flex items-center justify-between text-xs">
                  <span class="text-gray-400">Sesión: {lonja.diaSesion}</span>
                  <span class="bg-primary/10 text-primary px-2 py-0.5 rounded-full font-medium">{numProductos} productos</span>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    ))}

    <!-- Texto SEO -->
    <section class="mt-12 max-w-4xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">¿Qué es una lonja de cereales?</h2>
      <div class="text-gray-600 leading-relaxed space-y-4">
        <p>
          Una <strong>lonja de cereales</strong> es un mercado de referencia donde representantes de agricultores, comercializadores, cooperativas y la industria transformadora se reúnen periódicamente para fijar los precios orientativos de los cereales y otros productos agrarios.
        </p>
        <p>
          Las lonjas agropecuarias son instituciones con décadas de tradición en España. Cada semana, las mesas de cereales se reúnen para evaluar la oferta y demanda del mercado y establecer unas cotizaciones que sirven de guía para las transacciones comerciales en su zona de influencia.
        </p>
        <p>
          En esta página encontrarás el listado completo de lonjas que cotizan cereales en España, con acceso directo a los precios actualizados de cada una.
        </p>
      </div>
    </section>
  </div>
</Layout>
