---
import Layout from '../layouts/Layout.astro';
import VariacionBadge from '../components/VariacionBadge.astro';
import { getCereales, getLonjas, getSemanaActual, getPrecioMedioCereal, getVariacionMediaCereal, formatPrecio, formatFecha, getMesActual, getAnioActual } from '../utils/precios';
import { generateOrganizationSchema, generateWebSiteSchema } from '../utils/seo';

const base = import.meta.env.BASE_URL;
const semana = getSemanaActual();
const cereales = getCereales();
const lonjas = getLonjas();
const mes = getMesActual();
const anio = getAnioActual();

const preciosResumen = cereales.map(cereal => {
  const stats = getPrecioMedioCereal(semana, cereal.id);
  const variacion = getVariacionMediaCereal(semana, cereal.id);
  return { cereal, stats, variacion };
}).filter(p => p.stats !== null);

const seo = {
  title: `Precios de Cereales Hoy ${mes.charAt(0).toUpperCase() + mes.slice(1)} ${anio} - Todas las Lonjas de España`,
  description: `Precios actualizados de cereales en España: trigo a ${preciosResumen[0]?.stats ? formatPrecio(preciosResumen[0].stats.media) : '---'} €/t, cebada a ${preciosResumen[1]?.stats ? formatPrecio(preciosResumen[1].stats.media) : '---'} €/t. Compara precios en ${lonjas.length} lonjas. Actualizado ${formatFecha(semana.fechaFin)}.`,
};

const schema = [
  generateOrganizationSchema(),
  generateWebSiteSchema(),
];
---

<Layout seo={seo} schema={schema}>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-primary to-primary-light text-white py-12 sm:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold mb-4">
        Precios de Cereales Hoy en España
      </h1>
      <p class="text-lg sm:text-xl text-green-100 max-w-3xl">
        Cotizaciones actualizadas de <strong>{cereales.length} cereales</strong> en <strong>{lonjas.length} lonjas</strong> de toda España.
        Campaña {semana.campania}.
      </p>
      <p class="mt-3 text-sm text-green-200">
        Última actualización: <time datetime={semana.fechaFin}>{formatFecha(semana.fechaFin)}</time> &middot; Semana {semana.semana}
      </p>
    </div>
  </section>

  <!-- Tabla de Precios Resumen -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8">
    <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden">
      <div class="p-4 sm:p-6 border-b border-gray-100">
        <h2 class="text-xl font-bold text-gray-900">Precio medio de cereales esta semana</h2>
        <p class="text-sm text-gray-500 mt-1">Media de todas las lonjas de España &middot; {semana.campania}</p>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-left">
          <thead>
            <tr class="border-b-2 border-gray-200 bg-gray-50">
              <th class="py-3 px-4 sm:px-6 text-sm font-semibold text-gray-600">Cereal</th>
              <th class="py-3 px-4 sm:px-6 text-sm font-semibold text-gray-600 text-right">Precio medio (€/t)</th>
              <th class="py-3 px-4 sm:px-6 text-sm font-semibold text-gray-600 text-right hidden md:table-cell">Mínimo</th>
              <th class="py-3 px-4 sm:px-6 text-sm font-semibold text-gray-600 text-right hidden md:table-cell">Máximo</th>
              <th class="py-3 px-4 sm:px-6 text-sm font-semibold text-gray-600 text-right">Var. semanal</th>
              <th class="py-3 px-4 sm:px-6 text-sm font-semibold text-gray-600 text-center hidden sm:table-cell">Lonjas</th>
              <th class="py-3 px-2 sm:px-6"></th>
            </tr>
          </thead>
          <tbody>
            {preciosResumen.map((item, i) => (
              <tr class:list={['border-b border-gray-100 hover:bg-green-50/50 transition-colors', i % 2 === 0 ? '' : 'bg-gray-50/30']}>
                <td class="py-4 px-4 sm:px-6">
                  <a href={`${base}/precios/${item.cereal.slug}/`} class="font-semibold text-gray-900 hover:text-primary transition-colors">
                    {item.cereal.nombre}
                  </a>
                </td>
                <td class="py-4 px-4 sm:px-6 text-right font-bold text-lg text-gray-900 tabular-nums">
                  {formatPrecio(item.stats!.media)}
                </td>
                <td class="py-4 px-4 sm:px-6 text-right text-gray-500 tabular-nums hidden md:table-cell">
                  {formatPrecio(item.stats!.min)}
                </td>
                <td class="py-4 px-4 sm:px-6 text-right text-gray-500 tabular-nums hidden md:table-cell">
                  {formatPrecio(item.stats!.max)}
                </td>
                <td class="py-4 px-4 sm:px-6 text-right">
                  <VariacionBadge variacion={item.variacion} />
                </td>
                <td class="py-4 px-4 sm:px-6 text-center text-gray-500 hidden sm:table-cell">
                  {item.stats!.count}
                </td>
                <td class="py-4 px-2 sm:px-6 text-right">
                  <a href={`${base}/precios/${item.cereal.slug}/`} class="text-primary hover:text-primary-light text-sm font-medium whitespace-nowrap">
                    Ver &rarr;
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Lonjas Grid -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-16">
    <h2 class="text-2xl font-bold text-gray-900 mb-2">Precios por Lonja</h2>
    <p class="text-gray-500 mb-8">Consulta los precios en cada una de las {lonjas.length} lonjas agropecuarias de España.</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {lonjas.map(lonja => {
        const preciosLonja = semana.precios[lonja.id];
        const numProductos = preciosLonja ? Object.keys(preciosLonja).length : 0;
        return (
          <a href={`${base}/lonjas/${lonja.slug}/`} class="bg-white border border-gray-200 rounded-lg p-5 hover:shadow-md hover:border-primary/30 transition-all group">
            <h3 class="font-semibold text-gray-900 group-hover:text-primary transition-colors">{lonja.nombre}</h3>
            <p class="text-sm text-gray-500 mt-1">{lonja.comunidad}</p>
            <div class="mt-3 flex items-center justify-between">
              <span class="text-xs text-gray-400">Sesión: {lonja.diaSesion}</span>
              <span class="text-xs bg-primary/10 text-primary px-2 py-0.5 rounded-full font-medium">{numProductos} productos</span>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Contenido SEO -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-16">
    <div class="max-w-4xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">¿Qué son los precios de cereales en lonja?</h2>
      <div class="prose prose-gray max-w-none text-gray-600 leading-relaxed space-y-4">
        <p>
          Los <strong>precios de cereales en lonja</strong> son las cotizaciones de referencia que se fijan semanalmente en las lonjas agropecuarias de España. Estas lonjas son mercados donde productores, comercializadores y transformadores acuerdan los precios orientativos de los principales cereales: <strong>trigo, cebada, maíz, avena, girasol, colza, centeno y triticale</strong>.
        </p>
        <p>
          En España existen más de una docena de lonjas agropecuarias repartidas por todo el territorio, siendo las más relevantes las de <a href={`${base}/lonjas/leon/`} class="text-primary hover:text-primary-light">León</a>, <a href={`${base}/lonjas/toledo/`} class="text-primary hover:text-primary-light">Toledo</a>, <a href={`${base}/lonjas/sevilla/`} class="text-primary hover:text-primary-light">Sevilla</a>, <a href={`${base}/lonjas/valladolid/`} class="text-primary hover:text-primary-light">Valladolid</a>, <a href={`${base}/lonjas/albacete/`} class="text-primary hover:text-primary-light">Albacete</a> y <a href={`${base}/lonjas/ebro/`} class="text-primary hover:text-primary-light">Binéfar (Ebro)</a>.
        </p>
        <p>
          Los precios se expresan habitualmente en <strong>euros por tonelada (€/t)</strong>, en condiciones de origen agricultor (sobre camión), y siguen las condiciones de calidad establecidas por la O.C.M. Cereales y la FEGA para cada campaña agrícola. Estos precios son informativos y no vinculantes, sirviendo como referencia para la negociación individual entre compradores y vendedores.
        </p>
        <p>
          En nuestra web recopilamos y comparamos los precios de <strong>{lonjas.length} lonjas de toda España</strong>, actualizados semanalmente, para que agricultores, cooperativas, fabricantes de piensos y cualquier interesado pueda consultar la cotización de cereales de forma rápida, fiable y gratuita.
        </p>
      </div>
    </div>
  </section>
</Layout>
